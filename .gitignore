# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Build output
/build/
/dist/
# ASC Studio embeds apps/studio/frontend/dist via Wails, so that nested dist is tracked on purpose.
.gocache/

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
/asc
/asc-debug

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
.asc/

# Editor/IDE
# .idea/
# .vscode/
.cursor/

# BMAD (Build, Manage, Automate, Deploy) workflow system
_bmad/
_bmad-output/
worktrees/

# asc screenshots capture output (root-level only; internal/screenshots is code)
/screenshots/

# ASC Studio generated artifacts
/apps/studio/build/bin/
/apps/studio/build/darwin/Info.dev.plist
/apps/studio/frontend/package.json.md5
